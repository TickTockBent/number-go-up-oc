; Engine configuration file.
; NUMBER GOES UP - Godot 4.6.3

config_version=5

[application]

config/name="Number Goes Up"
config/description="There is a number. It goes up. That's it. That's the game."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://src/autoload/GameState.gd"
SaveSystem="*res://src/autoload/SaveSystem.gd"
