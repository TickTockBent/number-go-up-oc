# Godot import cache
.godot/

# Engine binary is too large for git (>100MB GitHub limit).
# Download Godot 4.6.3 stable into tools/ separately:
#   https://github.com/godotengine/godot/releases/download/4.6.3-stable/Godot_v4.6.3-stable_linux.x86_64
tools/Godot_v4.6.3-stable_linux.x86_64
tools/*.zip

# GodotSteam GDExtension binaries (compiled separately — see addons/godotsteam/INSTALL.md)
addons/godotsteam/linux64/*.so
addons/godotsteam/win64/*.dll
addons/godotsteam/osx/*.dylib

# OS junk
.DS_Store
Thumbs.db

# Editor swaps
*.swp
*.swo
*~
